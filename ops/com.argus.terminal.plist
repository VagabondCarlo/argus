<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.argus.terminal</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/agent/argus_v2/venv/bin/python</string>
        <string>-m</string>
        <string>notifications.render_terminal</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/agent/argus_v2</string>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/argus_terminal.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/argus_terminal.log</string>
</dict>
</plist>
